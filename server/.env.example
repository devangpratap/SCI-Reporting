# PostgreSQL connection string — works with any Postgres provider
# (Neon, Supabase, Railway, local, Lakebase, etc.)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Set to "mock" to use local JSON files (default, no DB needed)
# Set to "postgres" to query real data via DATABASE_URL
DATA_SOURCE=mock

# LLM for AI chat (OpenAI-compatible endpoint)
# Databricks Foundation Model API — uses your workspace token
DATABRICKS_HOST=your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your-personal-access-token
DATABRICKS_LLM_MODEL=databricks-meta-llama-3-3-70b-instruct
