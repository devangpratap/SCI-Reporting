# PostgreSQL — Lakebase or any Postgres provider
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# "mock" → local JSON files (no DB needed)
# "postgres" → query real data via DATABASE_URL
DATA_SOURCE=mock

# LLM for AI chat — any OpenAI-compatible provider
# Groq (free): get key at console.groq.com
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
