# Databricks SQL Warehouse credentials
# Get these Saturday when Databricks access is provided

DATABRICKS_HOST=your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your-personal-access-token
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id

# Set to "mock" to use local JSON files, "databricks" for real data
DATA_SOURCE=mock

# LLM for AI chat — served from Databricks using your $150 credits, same token as above
# Options: databricks-meta-llama-3-3-70b-instruct | databricks-dbrx-instruct | databricks-mixtral-8x7b-instruct
DATABRICKS_LLM_MODEL=databricks-meta-llama-3-3-70b-instruct

# PostgreSQL — static reports (Markdown) written here, Uvicorn reads from sci_static_reports table
POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432
POSTGRES_DB=your-db-name
POSTGRES_USER=your-user
POSTGRES_PASSWORD=your-password
POSTGRES_SSL=false
