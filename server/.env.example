# PostgreSQL — Lakebase or any Postgres provider
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# "mock" → local JSON files (no DB needed)
# "postgres" → query real data via DATABASE_URL
DATA_SOURCE=mock

# LLM for AI chat — Databricks Foundation Model API
# LLM_API_KEY = your Databricks personal access token
# LLM_BASE_URL = https://<your-workspace>.azuredatabricks.net/serving-endpoints
# LLM_MODEL options: databricks-meta-llama-3-3-70b-instruct | databricks-dbrx-instruct
LLM_API_KEY=your-databricks-pat
LLM_BASE_URL=https://your-workspace.azuredatabricks.net/serving-endpoints
LLM_MODEL=databricks-meta-llama-3-3-70b-instruct
