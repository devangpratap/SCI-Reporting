# Databricks SQL Warehouse credentials
# Get these Saturday when Databricks access is provided

DATABRICKS_HOST=your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your-personal-access-token
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id

# Set to "mock" to use local JSON files, "databricks" for real data
DATA_SOURCE=mock
